#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; -*-
#MISE description="Clone/fork a GitHub repo into ~/src/github and initialize jj + zellij"
#USAGE arg "[owner_repo]" help="GitHub repository in OWNER/REPO format"

set -euo pipefail

OWNER_REPO="${usage_owner_repo:-}"

if [[ -z "${OWNER_REPO}" ]]; then
  printf "Repository (owner/repo or URL): "
  read -r OWNER_REPO
fi

# Strip GitHub URL prefix if provided (e.g. https://github.com/owner/repo or https://github.com/owner/repo.git)
OWNER_REPO="${OWNER_REPO#https://github.com/}"
OWNER_REPO="${OWNER_REPO%.git}"
# Also handle trailing slash
OWNER_REPO="${OWNER_REPO%/}"

if [[ ! "${OWNER_REPO}" =~ ^[^/]+/[^/]+$ ]]; then
  echo "Error: repository must be in OWNER/REPO format or a GitHub URL"
  exit 1
fi

OWNER="${OWNER_REPO%%/*}"
REPO="${OWNER_REPO#*/}"
ROOT_DIR="${HOME}/src/github/${OWNER}"
TARGET_DIR="${ROOT_DIR}/${REPO}"

mkdir -p "${ROOT_DIR}"

remote_matches_target() {
  local remote_url="$1"
  [[ -n "${remote_url}" ]] && [[ "${remote_url}" =~ [:/]${OWNER}/${REPO}(\.git)?$ ]]
}

clone_repo() {
  echo "Cloning ${OWNER_REPO} into ${TARGET_DIR}"
  if command -v gh-repo-clone >/dev/null 2>&1 && [[ ! -e "${TARGET_DIR}" ]]; then
    (
      cd "${ROOT_DIR}"
      gh-repo-clone "${OWNER_REPO}"
    )
  else
    gh repo clone "${OWNER_REPO}" "${TARGET_DIR}"
  fi
}

if [[ -e "${TARGET_DIR}" ]]; then
  if [[ ! -d "${TARGET_DIR}" ]]; then
    echo "Error: target exists but is not a directory: ${TARGET_DIR}"
    exit 1
  fi

  if [[ -d "${TARGET_DIR}/.git" ]]; then
    ORIGIN_URL="$(git -C "${TARGET_DIR}" remote get-url origin 2>/dev/null || true)"
    UPSTREAM_URL="$(git -C "${TARGET_DIR}" remote get-url upstream 2>/dev/null || true)"

    if remote_matches_target "${ORIGIN_URL}" || remote_matches_target "${UPSTREAM_URL}"; then
      echo "Directory already contains a matching git repo; reusing ${TARGET_DIR}"
    else
      echo "Error: existing repo at ${TARGET_DIR} does not match ${OWNER_REPO}"
      echo "origin: ${ORIGIN_URL:-<missing>}"
      echo "upstream: ${UPSTREAM_URL:-<missing>}"
      exit 1
    fi
  elif [[ -z "$(ls -A "${TARGET_DIR}")" ]]; then
    clone_repo
  else
    echo "Error: target directory already exists and is not an empty directory or git repo: ${TARGET_DIR}"
    exit 1
  fi
else
  clone_repo
fi

cd "${TARGET_DIR}"

# Derive the correct gh account from jj's scoped user.email config.
# The jj config uses --when.repositories to set the glean email for work repos;
# we piggyback on that to decide which GitHub account to fork under.
# NOTE: We set GH_TOKEN rather than using `gh auth switch` to avoid mutating
# global gh state. In interactive shells, mise handles this automatically via
# the GH_TOKEN template in the global mise config.
JJ_EMAIL="$(jj config get user.email 2>/dev/null || true)"
if [[ "${JJ_EMAIL}" == "robert.jackson@glean.com" ]]; then
  GH_ACCOUNT="rwjblue-glean"
else
  GH_ACCOUNT="rwjblue"
fi
export GH_TOKEN="$(gh auth token --user "${GH_ACCOUNT}")"

PERMISSION="$(gh repo view "${OWNER_REPO}" --json viewerPermission --jq '.viewerPermission')"
TRACK_REMOTE="origin"

case "${PERMISSION}" in
  ADMIN|MAINTAIN|WRITE)
    echo "Commit access detected (${PERMISSION}); using origin"
    ;;
  *)
    if git remote get-url upstream >/dev/null 2>&1; then
      echo "No commit access detected (${PERMISSION}); upstream remote already exists"
    else
      echo "No commit access detected (${PERMISSION}); forking repository"
      gh repo fork --remote
    fi
    TRACK_REMOTE="upstream"
    ;;
esac

if [[ ! -d .jj ]]; then
  jj git init --colocate
fi

detect_default_branch() {
  local remote="$1"
  local branch

  branch="$(git symbolic-ref --quiet --short "refs/remotes/${remote}/HEAD" 2>/dev/null || true)"
  branch="${branch#${remote}/}"
  if [[ -n "${branch}" ]]; then
    printf "%s\n" "${branch}"
    return 0
  fi

  for candidate in main master; do
    if git show-ref --verify --quiet "refs/remotes/${remote}/${candidate}"; then
      printf "%s\n" "${candidate}"
      return 0
    fi
  done

  return 1
}

if ! DEFAULT_BRANCH="$(detect_default_branch "${TRACK_REMOTE}")"; then
  echo "Error: could not determine default branch for remote '${TRACK_REMOTE}'"
  exit 1
fi

echo "Tracking ${DEFAULT_BRANCH}@${TRACK_REMOTE} in jj"
set +e
TRACK_OUTPUT="$(jj bookmark track "${DEFAULT_BRANCH}" --remote="${TRACK_REMOTE}" 2>&1)"
TRACK_STATUS=$?
set -e

if [[ ${TRACK_STATUS} -ne 0 ]]; then
  if [[ "${TRACK_OUTPUT}" == *"already tracked"* || "${TRACK_OUTPUT}" == *"already tracking"* ]]; then
    echo "Bookmark already tracked: ${DEFAULT_BRANCH}@${TRACK_REMOTE}"
  else
    echo "${TRACK_OUTPUT}" >&2
    exit "${TRACK_STATUS}"
  fi
fi

SESSION_SWITCH_PLUGIN="https://github.com/mostafaqanbaryan/zellij-switch/releases/download/0.2.1/zellij-switch.wasm"

# Compute max session name length from the zellij socket path.
# Unix socket paths are limited (104 bytes on macOS, 108 on Linux).
ZELLIJ_VERSION="$(zellij --version | awk '{print $2}')"
ZELLIJ_SOCK_DIR="${TMPDIR%/}/zellij-$(id -u)/${ZELLIJ_VERSION}"
if [[ "$(uname -s)" == "Darwin" ]]; then
  SOCK_MAX=104
else
  SOCK_MAX=108
fi
# socket path = ZELLIJ_SOCK_DIR + "/" + SESSION_NAME
MAX_SESSION_LEN=$(( SOCK_MAX - ${#ZELLIJ_SOCK_DIR} - 1 - 1 ))

# Build session name: prefer repo-only, add owner prefix on collision,
# and truncate as a last resort to avoid hanging on socket path overflow.
choose_session_name() {
  local active_sessions
  active_sessions="$(zellij list-sessions --short --no-formatting 2>/dev/null || true)"

  # 1. Try repo name only
  if ! echo "${active_sessions}" | grep -Fxq "${REPO}"; then
    echo "${REPO}"
    return
  fi

  # 2. Repo collides with an active session — use owner-repo
  echo "${OWNER}-${REPO}"
}

truncate_session_name() {
  local name="$1"
  local max="$2"

  if (( ${#name} <= max )); then
    echo "${name}"
    return
  fi

  # Split on dashes, keep segments from the front until adding more would overflow.
  # Always keep the last segment so the name stays recognizable.
  local IFS='-'
  read -ra parts <<< "${name}"

  local last_idx=$(( ${#parts[@]} - 1 ))
  local last="${parts[${last_idx}]}"
  local result=""

  # Reserve room for the last segment (ellipsis + last).
  # The ellipsis (…) is 3 bytes in UTF-8; socket path limit is in bytes.
  local budget=$(( max - ${#last} - 3 ))

  for (( i=0; i < last_idx; i++ )); do
    local seg="${parts[${i}]}"
    local candidate
    if [[ -z "${result}" ]]; then
      candidate="${seg}"
    else
      candidate="${result}-${seg}"
    fi
    if (( ${#candidate} <= budget )); then
      result="${candidate}"
    else
      break
    fi
  done

  if [[ -n "${result}" ]]; then
    echo "${result}…${last}"
  else
    # Last segment alone is too long — hard truncate
    echo "${last:0:$(( max - 3 ))}…"
  fi
}

SESSION_NAME="$(choose_session_name)"
SESSION_NAME="$(truncate_session_name "${SESSION_NAME}" "${MAX_SESSION_LEN}")"

echo "Opening zellij session: ${SESSION_NAME}"

if [[ -n "${ZELLIJ:-}" ]]; then
  if ! zellij list-sessions --short 2>/dev/null | grep -Fxq "${SESSION_NAME}"; then
    zellij attach --create-background "${SESSION_NAME}" >/dev/null
  fi
  exec zellij pipe --plugin "${SESSION_SWITCH_PLUGIN}" -- "--session ${SESSION_NAME}"
fi

if zellij list-sessions --short 2>/dev/null | grep -Fxq "${SESSION_NAME}"; then
  exec zellij attach "${SESSION_NAME}"
else
  exec zellij attach --create "${SESSION_NAME}"
fi
