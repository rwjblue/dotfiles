{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_AUTOUPDATER": "1"
  },
  "model": "claude-opus-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARMOR_HOME=/Users/rwjblue/.armor /Users/rwjblue/.armor/policies/hooks.sh --policy claude-code-policy --hook command_execution --telemetry-enabled"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARMOR_HOME=/Users/rwjblue/.armor /Users/rwjblue/.armor/policies/hooks.sh --policy claude-code-policy --hook file_access_read --telemetry-enabled"
          }
        ],
        "matcher": "Read"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARMOR_HOME=/Users/rwjblue/.armor /Users/rwjblue/.armor/policies/hooks.sh --policy claude-code-policy --hook file_access_write --telemetry-enabled"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARMOR_HOME=/Users/rwjblue/.armor /Users/rwjblue/.armor/policies/hooks.sh --policy claude-code-policy --hook network_access --telemetry-enabled"
          }
        ],
        "matcher": "WebFetch|WebSearch"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARMOR_HOME=/Users/rwjblue/.armor /Users/rwjblue/.armor/policies/hooks.sh --policy claude-code-policy --hook mcp --telemetry-enabled"
          }
        ],
        "matcher": "mcp__.*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARMOR_HOME=/Users/rwjblue/.armor /Users/rwjblue/.armor/policies/hooks.sh --policy claude-code-policy --hook post_shell_execution --telemetry-enabled"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARMOR_HOME=/Users/rwjblue/.armor /Users/rwjblue/.armor/policies/hooks.sh --policy claude-code-policy --hook post_write_file --telemetry-enabled"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARMOR_HOME=/Users/rwjblue/.armor /Users/rwjblue/.armor/policies/hooks.sh --policy claude-code-policy --hook post_network_access --telemetry-enabled"
          }
        ],
        "matcher": "WebFetch"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARMOR_HOME=/Users/rwjblue/.armor /Users/rwjblue/.armor/policies/hooks.sh --policy claude-code-policy --hook post_mcp --telemetry-enabled"
          }
        ],
        "matcher": "mcp__.*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARMOR_HOME=/Users/rwjblue/.armor /Users/rwjblue/.armor/policies/hooks.sh --policy claude-code-policy --hook before_submit_prompt --telemetry-enabled"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARMOR_HOME=/Users/rwjblue/.armor /Users/rwjblue/.armor/policies/hooks.sh --policy claude-code-policy --hook stop --telemetry-enabled"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARMOR_HOME=/Users/rwjblue/.armor /Users/rwjblue/.armor/policies/hooks.sh --policy claude-code-policy --hook session_start --telemetry-enabled"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ARMOR_HOME=/Users/rwjblue/.armor /Users/rwjblue/.armor/policies/hooks.sh --policy claude-code-policy --hook session_end --telemetry-enabled"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.local/share/mise/shims/ccstatusline",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "glean-core@glean-plugins": true,
    "pyright-lsp@claude-plugins-official": true,
    "oncall-pact@pact-plugins": true,
    "glean-skills@glean-plugins": true,
    "superpowers@superpowers-marketplace": true,
    "vercel-plugin@vercel-vercel-plugin": true
  },
  "extraKnownMarketplaces": {
    "pact-plugins": {
      "source": {
        "source": "directory",
        "path": "/Users/rwjblue/src/github/askscio/claude-plugins-pact"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "vercel-vercel-plugin": {
      "source": {
        "source": "directory",
        "path": "/Users/rwjblue/.cache/plugins/github.com-vercel-vercel-plugin"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "auto"
}
